---
import Section from "./Section.astro";
import type { SkillGroupProps } from "@types";

interface Props {
  skills: SkillGroupProps[];
}

const { skills } = Astro.props;
---

<Section text="Technical Skills" href="skills">
  <div class="grid gap-6 sm:grid-cols-2">
    {
      skills.map(({ category, items }) => (
        <div class="rounded-2xl border border-slate-200/60 bg-[#ffffff] p-6 shadow-sm transition-all duration-300 hover:border-primary/45 hover:shadow-md">
          <h3 class="mb-4 font-serif text-xl font-semibold text-white flex items-center gap-2">
            <span class="h-2 w-2 rounded-full bg-primary" />
            {category}
          </h3>
          <div class="flex flex-wrap gap-2">
            {items.map((item) => (
              <span class="rounded-lg bg-slate-50 px-3 py-1.5 text-sm text-neutral transition-all duration-200 hover:bg-primary/10 hover:text-primary border border-slate-200/50">
                {item}
              </span>
            ))}
          </div>
        </div>
      ))
    }
  </div>
</Section>
