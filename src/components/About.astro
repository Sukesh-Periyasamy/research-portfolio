---
import Section from "./Section.astro";
import { Image } from "astro:assets";
import type { AboutProps, HeroProps } from "@types";

type Props = AboutProps & Pick<HeroProps, "name">;

const { description, image, name } = Astro.props;
---

<Section text="About Me" href="about">
  <div class="flex flex-col items-center gap-12 md:flex-row md:items-start md:gap-8">
    <div class="w-auto md:pr-5 space-y-5">
      {
        description.split("\n\n").map((para) => (
          <p class="text-base text-neutral leading-relaxed text-justify md:text-left">
            {para}
          </p>
        ))
      }
    </div>
    <div class="h-80 w-64 shrink-0 rotate-[5deg] bg-[#ffffff] p-4 shadow-xl border border-slate-200/60 md:rotate-[7deg] self-center md:self-start mt-4">
      <Image
        class="object-cover"
        src={image}
        width="260"
        height="260"
        alt={name}
      />
    </div>
  </div>
</Section>
