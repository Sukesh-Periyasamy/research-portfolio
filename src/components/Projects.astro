---
import Section from "./Section.astro";
import { Image } from "astro:assets";
import type { ProjectProps } from "@types";

interface Props {
  projects: ProjectProps[];
}

const { projects } = Astro.props;
---

<Section text="Featured Projects" href="projects">
  {
    projects.map(({ name, summary, image, linkPreview, linkSource, tech }, index) => {
      const top = 98 + index * 40;
      return (
        <div
          style={`top: ${top}px;`}
          class="sticky mb-12 rounded-2xl border border-neutral/10 bg-black"
        >
          <div class="bg-difu relative z-1 grid h-145 w-full grid-rows-2 rounded-2xl bg-white shadow-xl border border-slate-200/50 before:absolute before:inset-0 before:z-[-1] before:rounded-2xl before:bg-[url(/raja.png)] before:bg-size-[128px] before:bg-repeat before:opacity-5 before:content-[''] sm:grid-cols-2 sm:grid-rows-1 md:h-[400px]">
            <div class="px-6 py-8 flex flex-col justify-between">
              <div>
                <h3 class="mb-4 font-serif text-3xl font-medium text-primary">
                  {name}
                </h3>
                <p class="text-base text-neutral mb-5">{summary}</p>
                {tech && (
                  <div class="flex flex-wrap gap-2 mb-4">
                    {tech.map((t) => (
                      <span class="rounded bg-white/5 border border-white/10 px-2 py-0.5 text-xs text-neutral/90">
                        {t}
                      </span>
                    ))}
                  </div>
                )}
              </div>
              <div class="flex gap-5 text-white">
                {linkSource && (
                  <a
                    href={linkSource}
                    target="_blank"
                    class="after:relative after:-bottom-1.25 after:content-[url(/external.svg)] hover:underline"
                  >
                    Source
                  </a>
                )}
                {linkPreview && (
                  <a
                    href={linkPreview}
                    target="_blank"
                    class="after:relative after:-bottom-1.25 after:content-[url(/external.svg)] hover:underline"
                  >
                    Preview
                  </a>
                )}
              </div>
            </div>
            <div class="flex items-center justify-center p-6 overflow-hidden">
              <Image
                class="max-h-full max-w-full rounded-xl object-contain"
                src={image}
                alt={name}
                width="736"
                height="483"
              />
            </div>
          </div>
        </div>
      );
    })
  }
</Section>
